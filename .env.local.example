# ============================================================
# hoshiorange-official 環境変数サンプル
# このファイルを `.env.local` にコピーして値を埋めてください。
# `.env.local` は .gitignore 済みでコミットされません。
# ============================================================

# --- YouTube Data API v3（サーバー専用）---
# Google Cloud Console > APIs & Services > Credentials で発行した API キーを設定。
# NEXT_PUBLIC_ を付けないこと（付けるとブラウザに露出します）。
YOUTUBE_API_KEY=

# YouTube チャンネル ID（UC で始まる文字列）。
# 例: "UCxxxxxxxxxxxxxxxxxxxxxx"
# チャンネルページの URL や YouTube Studio から取得できます。
YOUTUBE_CHANNEL_ID=

# --- ツイキャス（TwitCasting API v2・すべてサーバー専用 / NEXT_PUBLIC_ を付けない）---
# 認証は 3 段フォールバック:
#   1. TWITCASTING_ACCESS_TOKEN（Bearer）があれば最優先で使用（配信状況をリッチ表示）
#   2. 無ければ TWITCASTING_CLIENT_ID / TWITCASTING_CLIENT_SECRET の Basic 認証を使用
#   3. どちらも無い／API エラー時は「ツイキャスを見る →」リンクカードにフォールバック
# 取得には https://twitcasting.tv/developer.php でアプリ登録して ClientID / ClientSecret を発行。
# ACCESS_TOKEN は対象ユーザー（hoshiorange 本人）の OAuth2 アクセストークン。
TWITCASTING_ACCESS_TOKEN=
TWITCASTING_CLIENT_ID=
TWITCASTING_CLIENT_SECRET=
# 取得対象ユーザー。未設定なら 'hoshiorange'（screen_id）を使用します。任意。
# TWITCASTING_USER_ID=hoshiorange

# --- X (Twitter) 埋め込みタイムライン用 ---
# 【現在未使用（将来用）】Latest セクションの X 埋め込みはツイキャス配信状況に置き換え済み。
# 再度 X 埋め込みを使う場合に備えて変数定義のみ残しています。
# @ を抜いたユーザー名のみ（例: "hoshiorange"）。
NEXT_PUBLIC_X_USERNAME=

# --- サイト URL（OGP / sitemap などで使用）---
# 本番ドメイン（例: "https://hoshiorange.example.com"）。
# 未設定時は localhost:3000 を base として動作します。
NEXT_PUBLIC_SITE_URL=

# ============================================================
# hoshiorange-official 環境変数サンプル
# このファイルを `.env.local` にコピーして値を埋めてください。
# `.env.local` は .gitignore 済みでコミットされません。
# ============================================================

# --- YouTube Data API v3（サーバー専用）---
# Google Cloud Console > APIs & Services > Credentials で発行した API キーを設定。
# NEXT_PUBLIC_ を付けないこと（付けるとブラウザに露出します）。
YOUTUBE_API_KEY=

# YouTube チャンネル ID（UC で始まる文字列）。
# 例: "UCxxxxxxxxxxxxxxxxxxxxxx"
# チャンネルページの URL や YouTube Studio から取得できます。
YOUTUBE_CHANNEL_ID=

# --- X (Twitter) 埋め込みタイムライン用 ---
# @ を抜いたユーザー名のみ（例: "hoshiorange"）。
# クライアント側で参照するため NEXT_PUBLIC_ を付けています。
NEXT_PUBLIC_X_USERNAME=

# --- サイト URL（OGP / sitemap などで使用）---
# 本番ドメイン（例: "https://hoshiorange.example.com"）。
# 未設定時は localhost:3000 を base として動作します。
NEXT_PUBLIC_SITE_URL=
